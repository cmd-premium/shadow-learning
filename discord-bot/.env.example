# Copy to .env and fill in. Never commit .env or your token.

# Your Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_bot_token_here

# Key server (Railway or local)
KEY_SERVER_URL=https://shadow-learning-production.up.railway.app

# Shared secret: same value on Railway (ADD_KEY_SECRET) and here. Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADD_KEY_SECRET=25aa75d02dbf3ff8bb8f77dfa91b09fe60c7c15130efc2d4ce01e8c162d6c365

# Discord role name required to use !code (default: Staff)
STAFF_ROLE_NAME=Customer
