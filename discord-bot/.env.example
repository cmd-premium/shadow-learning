# Copy to .env and fill in. Never commit .env or your token.

# Your Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_bot_token_here

# Key server (Railway or local). Must have ADD_KEY_SECRET set.
KEY_SERVER_URL=https://shadow-learning-production.up.railway.app

# Same secret you set on the key server (Railway env ADD_KEY_SECRET)
ADD_KEY_SECRET=your_shared_secret_here

# Discord role name required to use !code (default: Staff)
STAFF_ROLE_NAME=Staff
